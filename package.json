{
  "name": "topopass",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "npm run test:route-scoring && npm run test:mock-exam && npm run test:mock-selection && npm run test:admin-questions && npm run test:db-persistence",
    "test:route-scoring": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test lib/routeScoring.test.ts",
    "test:mock-exam": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test lib/mockExamEngine.test.ts",
    "test:mock-selection": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test lib/mockExamSelection.test.ts",
    "test:admin-questions": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test lib/admin/questionValidation.test.ts lib/admin/questionAdminHelpers.test.ts",
    "test:db-persistence": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test lib/db/questionRepository.test.ts lib/db/attemptRepository.test.ts",
    "map:render:kings-cross-euston": "node scripts/maps/render-kings-cross-euston-map.mjs",
    "map:graph:kings-cross-euston": "node scripts/maps/generate-kings-cross-euston-route-graph.mjs",
    "map:build:kings-cross-euston": "npm run map:render:kings-cross-euston && npm run map:graph:kings-cross-euston"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "mapbox-gl": "^3.7.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^22.7.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.12.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3"
  }
}
