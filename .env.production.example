# TopoPass production environment template
# Copy values into untracked runtime env files on the EC2 host, for example:
# /opt/topopass/env/app.env and /opt/topopass/env/proxy.env
#
# Do not commit real production values.

# Domain/reverse proxy values
APP_DOMAIN=example.com
WWW_DOMAIN=www.example.com
SUPABASE_DOMAIN=supabase.example.com
ACME_EMAIL=admin@example.com

# Public browser-safe values
# These are visible to the browser by design. The Supabase anon key is not a
# service-role key and must remain constrained by Supabase RLS policies.
NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_SUPABASE_URL=https://supabase.example.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key-placeholder

# Self-hosted Supabase public URL values
SUPABASE_PUBLIC_URL=https://supabase.example.com
API_EXTERNAL_URL=https://supabase.example.com
SITE_URL=https://example.com
ADDITIONAL_REDIRECT_URLS=https://example.com,https://www.example.com

# Backup values for host-side scripts only
BACKUP_S3_BUCKET=your-topopass-backup-bucket
BACKUP_S3_PREFIX=topopass
POSTGRES_CONTAINER_NAME=supabase-db
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-on-host-only
COMPOSE_PROJECT_DIR=/srv/topopass
BACKUP_WORK_DIR=/srv/topopass-data/backups/postgres
BACKUP_LOG_DIR=/var/log/topopass/backups
STORAGE_SOURCE_DIR=/srv/topopass-data/storage
MAX_BACKUP_AGE_HOURS=36

# Server/runtime values
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Do not commit the real host-side version of this file.
# Do not add private Supabase service keys here.
# Do not print database passwords, admin passwords, cookies, or API tokens.
# Seed-only variables such as SUPABASE_SEED_ADMIN_EMAIL and
# SUPABASE_SEED_ADMIN_PASSWORD are not required for normal app runtime.
