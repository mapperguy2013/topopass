# TopoPass app runtime environment example
# Copy to /srv/topopass/env/app.env on the EC2 host.
#
# Do not commit the real host file.
# Do not add Supabase service-role keys or private AWS credentials here.

NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Public browser-safe values.
# For the first IP-only smoke test, use the EC2 public IP URL.
# After DNS is connected, switch this to the HTTPS app domain.
NEXT_PUBLIC_SITE_URL=http://13.134.170.158

# Use your managed Supabase public URL for now.
# When self-hosted Supabase is added later, this can become
# https://supabase.your-domain.example.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key-placeholder

# Public Mapbox token used by map-click practice and review maps.
NEXT_PUBLIC_MAPBOX_TOKEN=your-public-mapbox-token-placeholder
