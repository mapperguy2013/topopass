# TopoPass Caddy reverse proxy environment example
# Copy to /srv/topopass/env/proxy.env on the EC2 host.
#
# Do not commit the real host file.

# Current no-domain smoke test mode.
# This makes Caddy serve the app over plain HTTP on the EC2 public IP.
# Current temporary smoke-test URL: http://13.134.170.158
APP_DOMAIN=:80

# Placeholder-only addresses keep these optional routes from requesting public
# certificates before real DNS exists.
WWW_DOMAIN=http://www.topopass.invalid
SUPABASE_DOMAIN=http://supabase.topopass.invalid

# Required when APP_DOMAIN/WWW_DOMAIN/SUPABASE_DOMAIN are changed to real
# HTTPS hostnames later.
ACME_EMAIL=admin@example.com

# Future domain mode example:
# APP_DOMAIN=topopass.co.uk
# WWW_DOMAIN=www.topopass.co.uk
# SUPABASE_DOMAIN=supabase.topopass.co.uk
# ACME_EMAIL=admin@topopass.co.uk
