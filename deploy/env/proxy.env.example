# TopoPass Caddy reverse proxy environment example
# Copy to /srv/topopass/env/proxy.env on the EC2 host.
#
# Do not commit the real host file.

# Current no-domain smoke test mode.
# This makes Caddy serve the app over plain HTTP on the EC2 public IP.
# Current temporary smoke-test URL: http://13.134.170.158
APP_DOMAIN=:80

# Required when APP_DOMAIN is changed to a real HTTPS hostname later.
ACME_EMAIL=admin@example.com

# Future domain mode example:
# APP_DOMAIN=topopass.co.uk
# ACME_EMAIL=admin@topopass.co.uk
#
# WWW redirects and Supabase subdomain proxying are intentionally not active
# during the public-IP HTTP phase. Add them back only when Route 53 and HTTPS
# are resumed.
