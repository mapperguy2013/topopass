{
	email {$ACME_EMAIL:admin@example.com}
}

# Temporary Step 48A public-IP mode:
# APP_DOMAIN defaults to :80, so Caddy serves plain HTTP on the EC2 Elastic IP.
# Do not add HTTPS redirects here until Route 53/domain work resumes.
{$APP_DOMAIN::80} {
	encode zstd gzip

	log {
		output file /var/log/caddy/app-access.log
		format json
	}

	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "DENY"
	}

	reverse_proxy app:3000
}
