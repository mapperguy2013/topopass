# Supabase public project config.
# These values are safe to expose to browser code.
# Do not add private server-only keys to NEXT_PUBLIC variables.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional manual seed command credentials.
# Use a normal authenticated Supabase admin account with profiles.role = admin.
SUPABASE_SEED_ADMIN_EMAIL=
SUPABASE_SEED_ADMIN_PASSWORD=

# Optional map provider token used by existing demo map-click questions.
NEXT_PUBLIC_MAPBOX_TOKEN=
