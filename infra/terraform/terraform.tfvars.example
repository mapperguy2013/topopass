project_name = "topopass"
environment  = "production"
aws_region   = "eu-west-2"

instance_type       = "t3.small"
root_volume_size_gb = 30
data_volume_size_gb = 50

allowed_http_cidr_blocks = ["0.0.0.0/0"]
allowed_http_ipv6_cidr_blocks = []

# SSH is disabled by default. Prefer SSM Session Manager.
ssh_cidr_blocks = []
key_name        = null

# Optional existing network. Leave null to create a small VPC and public subnet.
vpc_id           = null
public_subnet_id = null

# Optional ECR registry hint used by host documentation only.
ecr_registry = "123456789012.dkr.ecr.eu-west-2.amazonaws.com"

# Optional Route 53 records for example.com, www.example.com, and
# supabase.example.com. Keep disabled until the hosted zone is ready.
enable_route53_records = false
route53_zone_name      = "example.com"
route53_zone_id        = ""
domain_name            = "example.com"
supabase_subdomain     = "supabase"

backup_retention_days          = 14
backup_bucket_name             = ""
backup_s3_prefix               = "topopass"
backup_transition_to_ia_days   = 0
cloudwatch_log_retention_days  = 14
alert_email                    = ""
cpu_alarm_threshold_percent    = 80
memory_alarm_threshold_percent = 85
disk_alarm_threshold_percent   = 85
alarm_evaluation_periods       = 2

common_tags = {
  Owner = "topopass"
}
