# TopoPass Docker runtime environment example
# Copy this file to .env.docker for local Docker Compose, or create an
# equivalent untracked runtime env file on the EC2 host.
#
# Do not commit .env.docker or any real production secrets.

# Public browser-safe app values
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-managed-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key-placeholder

# Runtime settings
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Do not add private Supabase service keys here.
# Do not add database passwords, admin passwords, cookies, or API tokens here.
